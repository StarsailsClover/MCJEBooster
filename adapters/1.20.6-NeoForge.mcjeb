{
  "adapterId": "1.20.6-NeoForge",
  "minecraftVersion": "1.20.6",
  "loaderType": "NEOFORGE",
  "loaderVersion": "20.6.x",
  "requiredJavaVersion": 21,
  "adapterVersion": "1.0",
  "priority": 110,
  
  "classMappings": {
    "MinecraftServer": "net.minecraft.server.MinecraftServer",
    "ServerLevel": "net.minecraft.server.level.ServerLevel",
    "Level": "net.minecraft.world.level.Level",
    "LevelChunk": "net.minecraft.world.level.chunk.LevelChunk",
    "Entity": "net.minecraft.world.entity.Entity",
    "BlockEntity": "net.minecraft.world.level.block.entity.BlockEntity",
    "ChunkSource": "net.minecraft.world.level.chunk.ChunkSource",
    "ServerChunkCache": "net.minecraft.server.level.ServerChunkCache",
    "ServerEntityManager": "net.minecraft.world.level.entity.ServerEntityManager",
    "PersistentEntitySectionManager": "net.minecraft.world.level.entity.PersistentEntitySectionManager",
    "DataComponents": "net.minecraft.core.component.DataComponents",
    "NeoForge": "net.neoforged.neoforge.common.NeoForge",
    "NeoForgeEventBus": "net.neoforged.neoforge.common.NeoForge.EVENT_BUS"
  },
  
  "methodMappings": {
    "MinecraftServer.tickServer": "tickServer",
    "ServerLevel.tick": "tick",
    "ServerLevel.tickChunk": "tickChunk",
    "ServerChunkCache.tick": "tick",
    "Entity.tick": "tick",
    "BlockEntity.tick": "tick",
    "ServerEntityManager.tick": "tick",
    "PersistentEntitySectionManager.tick": "tick",
    "NeoForgeEventBus.post": "post"
  },
  
  "fieldMappings": {
    "Level.entities": "entitiesById",
    "Level.blockEntities": "blockEntityTickers",
    "Level.players": "players",
    "MinecraftServer.levels": "levels",
    "ServerLevel.entityManager": "entityManager",
    "ServerLevel.entitySectionManager": "entitySectionManager",
    "NeoForge.EVENT_BUS": "EVENT_BUS"
  },
  
  "methodDescriptors": {
    "MinecraftServer.tickServer": "(Ljava/util/function/BooleanSupplier;)V",
    "ServerLevel.tick": "(Ljava/util/function/BooleanSupplier;)V",
    "Entity.tick": "()V",
    "BlockEntity.tick": "()V",
    "ServerEntityManager.tick": "()V",
    "NeoForgeEventBus.post": "(Lnet/neoforged/neoforge/event/Event;)Z"
  },
  
  "tickMethodTarget": "MinecraftServer.tickServer",
  "entityTickMethodTarget": "ServerLevel.tick",
  "blockTickMethodTarget": "ServerLevel.tickBlockEntities",
  "chunkProviderClass": "ServerChunkCache",
  "worldClass": "ServerLevel",
  "entityClass": "Entity",
  "entityListField": "entitiesById",
  
  "regionSize": 16,
  "recommendedWorkerCount": 4,
  "tickTimeoutMs": 45,
  
  "supportedFeatures": [
    "MULTITHREADED_ENTITIES",
    "MULTITHREADED_TILE_ENTITIES",
    "ASYNC_CHUNK_LOADING",
    "ASYNC_PATHFINDING",
    "SYNC_POINT_BARRIERS",
    "AUTO_ROLLBACK",
    "DYNAMIC_REGION_BALANCING",
    "FORGE_EVENT_BUS"
  ],
  
  "requiredJvmArgs": [
    "--add-opens=java.base/java.util.jar=ALL-UNNAMED",
    "--add-opens=java.base/java.lang.invoke=ALL-UNNAMED",
    "-XX:+UseG1GC",
    "-XX:MaxGCPauseMillis=50"
  ],
  
  "neoForgeSpecific": {
    "eventBusCompatibility": true,
    "modTickEvents": [
      "net.neoforged.neoforge.event.TickEvent.LevelTickEvent",
      "net.neoforged.neoforge.event.TickEvent.ServerTickEvent"
    ],
    "threadSafeMods": [],
    "threadUnsafeMods": [
      "minecraft",
      "neoforge"
    ]
  },
  
  "notes": [
    "Java 21 required for 1.20.5+",
    "NeoForge 20.6.x for 1.20.6",
    "Fork of Forge with different package names",
    "net.neoforged package prefix",
    "Component system introduced in 1.20.5"
  ]
}
